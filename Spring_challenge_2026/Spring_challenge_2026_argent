import sys
from collections import deque


# The grid is small, so we can afford a little pathfinding every turn.
# Silver league variant: front-load training, then build and maintain a
# compact orchard against the shack. Water is a bonus only inside that orchard.

RESOURCE_TYPES = ("PLUM", "LEMON", "APPLE", "BANANA", "IRON", "WOOD")
TRAIN_FRUITS = ("PLUM", "LEMON", "APPLE")
DIRS = ((1, 0), (-1, 0), (0, 1), (0, -1))
INF = 10**9

EARLY_TROLL_TARGET = 4
TRAIN_RUSH_END = 35
EARLY_TRAIN_PLAN = (1, 1, 1, 1)
FALLBACK_TRAIN_PLAN = (1, 1, 1, 0)
CATCHUP_TRAIN_END = 165
ORCHARD_TROLL_TARGET = 6
ORCHARD_TRAIN_START = 120
ORCHARD_TRAIN_END = 205
ORCHARD_TRAIN_MIN_TREES = 0
ORCHARD_TRAIN_PLAN = (1, 2, 1, 1)
WOOD_START_TURN = 70
MIDGAME_LOCAL_TURN = 120
WOOD_HARVEST_TURN = 200
WOOD_ALL_IN_TURN = 235
EARLY_ORCHARD_START_TURN = 45
EARLY_ORCHARD_TARGET = 4
BANANA_PLANT_START_TURN = 160
PLANT_UNTIL_TURN = 245
ORCHARD_TARGET = 8
ORCHARD_RADIUS = 5
PLANT_RADIUS = 1
PLANT_MAX_TRAVEL = 5
EARLY_PLANT_PRIORITY = ("APPLE", "PLUM", "LEMON")
BANANA_PLANT_PRIORITY = ("BANANA",)
WATER_REQUIRED_AFTER = 160
ENDGAME_LOCAL_TURN = 240
ENDGAME_STRICT_TURN = 255


def ceil_div(a, b):
    return (a + b - 1) // b if b > 0 else INF


def train_cost(plan, troll_count):
    move_speed, capacity, harvest_power, chop_power = plan
    return {
        "PLUM": troll_count + move_speed * move_speed,
        "LEMON": troll_count + capacity * capacity,
        "APPLE": troll_count + harvest_power * harvest_power,
        "IRON": troll_count + chop_power * chop_power,
    }


def can_pay(cost, stock):
    return all(stock[res] >= amount for res, amount in cost.items())


def training_options(troll_count, turn, orchard_size=0):
    if troll_count < EARLY_TROLL_TARGET and turn <= TRAIN_RUSH_END:
        return [EARLY_TRAIN_PLAN, FALLBACK_TRAIN_PLAN]
    if troll_count < EARLY_TROLL_TARGET and turn <= CATCHUP_TRAIN_END:
        return [EARLY_TRAIN_PLAN, FALLBACK_TRAIN_PLAN]
    if (
        ORCHARD_TRAIN_START <= turn <= ORCHARD_TRAIN_END
        and orchard_size >= ORCHARD_TRAIN_MIN_TREES
        and troll_count < ORCHARD_TROLL_TARGET
    ):
        return [ORCHARD_TRAIN_PLAN, EARLY_TRAIN_PLAN, FALLBACK_TRAIN_PLAN]
    return []


def pick_training_plan(troll_count, stock, turn, orchard_size=0):
    for plan in training_options(troll_count, turn, orchard_size):
        if can_pay(train_cost(plan, troll_count), stock):
            return plan
    return None


def wanted_training_cost(troll_count, stock, turn, orchard_size=0):
    options = training_options(troll_count, turn, orchard_size)
    if not options:
        return {}

    for plan in options:
        cost = train_cost(plan, troll_count)
        if can_pay(cost, stock):
            return cost
    return train_cost(options[0], troll_count)


width, height = [int(i) for i in input().split()]
base = (0, 0)
iron_cells = []
water_cells = set()
walkable = set()

for y in range(height):
    line = input()
    for x, char in enumerate(line):
        pos = (x, y)
        if char == "0":
            base = pos
            walkable.add(pos)
        elif char == ".":
            walkable.add(pos)
        elif char == "+":
            iron_cells.append(pos)
        elif char == "~":
            water_cells.add(pos)


def bfs(start):
    distances = {start: 0}
    queue = deque([start])
    while queue:
        x, y = queue.popleft()
        for dx, dy in DIRS:
            nxt = (x + dx, y + dy)
            if nxt in walkable and nxt != base and nxt not in distances:
                distances[nxt] = distances[(x, y)] + 1
                queue.append(nxt)
    return distances


distances_from = {cell: bfs(cell) for cell in walkable}

drop_cells = []
for dx, dy in DIRS:
    cell = (base[0] + dx, base[1] + dy)
    if cell in walkable:
        drop_cells.append(cell)

mine_spots = []
for mx, my in iron_cells:
    for dx, dy in DIRS:
        spot = (mx + dx, my + dy)
        if spot in walkable:
            mine_spots.append(spot)
mine_spots = list(dict.fromkeys(mine_spots))

good_plant_cells = set()
for x, y in walkable:
    if (x, y) == base:
        continue
    for dx, dy in DIRS:
        if (x + dx, y + dy) in water_cells:
            good_plant_cells.add((x, y))
            break

plant_cells = {
    cell
    for cell in walkable
    if cell != base
    and max(abs(cell[0] - base[0]), abs(cell[1] - base[1])) == 1
}
ORCHARD_TARGET = min(ORCHARD_TARGET, len(plant_cells))
EARLY_ORCHARD_TARGET = min(EARLY_ORCHARD_TARGET, ORCHARD_TARGET)


def dist(a, b):
    if a == b:
        return 0
    return distances_from.get(a, {}).get(b, INF)


def is_next_to_base(pos):
    return abs(pos[0] - base[0]) + abs(pos[1] - base[1]) == 1


def distance_to_drop(pos):
    if is_next_to_base(pos):
        return 0
    return min((dist(pos, cell) for cell in drop_cells), default=INF)


def best_drop_cell(pos, reserved):
    best_cell = None
    best_dist = INF
    for cell in drop_cells:
        if cell in reserved and cell != pos:
            continue
        d = dist(pos, cell)
        if d < best_dist:
            best_dist = d
            best_cell = cell
    if best_cell is None:
        return base
    return best_cell


def best_mine_spot(pos, reserved):
    best_cell = None
    best_dist = INF
    for cell in mine_spots:
        if cell in reserved and cell != pos:
            continue
        d = dist(pos, cell)
        if d < best_dist:
            best_dist = d
            best_cell = cell
    return best_cell, best_dist


def best_plant_cell(pos, reserved, turn):
    best_cell = None
    best_score = INF
    best_dist = INF
    candidates = []
    for cell in plant_cells:
        if cell in current_tree_positions:
            continue
        if cell in reserved and cell != pos:
            continue
        travel = dist(pos, cell)
        drop_distance = distance_to_drop(cell)
        if travel >= INF or drop_distance >= INF:
            continue
        if drop_distance > PLANT_RADIUS:
            continue

        candidates.append((cell, travel, drop_distance))

    water_candidates = [candidate for candidate in candidates if candidate[0] in good_plant_cells]
    if turn >= WATER_REQUIRED_AFTER and water_candidates:
        candidates = water_candidates

    for cell, travel, drop_distance in candidates:
        # Shack distance dominates everything. Among equally close cells, prefer
        # water-side cells, then the shortest movement for the current troll.
        score = 1000 * drop_distance + 4 * travel
        if cell in good_plant_cells:
            score -= 120
        if cell == pos:
            score -= 40
        if score < best_score:
            best_score = score
            best_dist = travel
            best_cell = cell
    return best_cell, best_dist


def should_keep_orchard_tree(tree, turn):
    if tree["pos"] not in plant_cells:
        return False
    if turn < WOOD_HARVEST_TURN:
        return True
    if turn < WOOD_ALL_IN_TURN:
        return tree["size"] < 4
    return tree["size"] < 3


def carried_total(troll):
    return sum(troll["carry"].values())


def plant_priority(turn):
    if turn < BANANA_PLANT_START_TURN:
        return EARLY_PLANT_PRIORITY
    return BANANA_PLANT_PRIORITY


def orchard_target(turn):
    if turn < BANANA_PLANT_START_TURN:
        return EARLY_ORCHARD_TARGET
    return ORCHARD_TARGET


def can_spend_seed(fruit, stock, wanted_cost, turn, core_ready):
    if turn >= BANANA_PLANT_START_TURN:
        return fruit == "BANANA"
    if fruit == "BANANA":
        return False
    if core_ready:
        return True
    return stock[fruit] > wanted_cost.get(fruit, 0) + 1


def carried_seed_type(troll, stock, wanted_cost, turn, orchard_size, core_ready):
    if turn < EARLY_ORCHARD_START_TURN or turn >= PLANT_UNTIL_TURN:
        return None
    if orchard_size >= orchard_target(turn):
        return None
    for fruit in plant_priority(turn):
        if not can_spend_seed(fruit, stock, wanted_cost, turn, core_ready):
            continue
        if troll["carry"][fruit] > 0:
            return fruit
    return None


def stock_seed_type(stock, wanted_cost, turn, orchard_size, core_ready):
    if turn < EARLY_ORCHARD_START_TURN or turn >= PLANT_UNTIL_TURN:
        return None
    if orchard_size >= orchard_target(turn):
        return None
    for fruit in plant_priority(turn):
        if not can_spend_seed(fruit, stock, wanted_cost, turn, core_ready):
            continue
        if stock[fruit] > 0:
            return fruit
    return None


def has_seed_in_stock(stock, wanted_cost, turn, core_ready):
    if turn < EARLY_ORCHARD_START_TURN or turn >= PLANT_UNTIL_TURN:
        return False
    for fruit in plant_priority(turn):
        if not can_spend_seed(fruit, stock, wanted_cost, turn, core_ready):
            continue
        if stock[fruit] > 0:
            return True
    return False


turn = 0

while True:
    inventories = []
    for _ in range(2):
        values = [int(j) for j in input().split()]
        inventories.append(dict(zip(RESOURCE_TYPES, values)))

    stock = inventories[0]

    tree_count = int(input())
    trees = []
    current_tree_positions = set()
    for index in range(tree_count):
        data = input().split()
        tree = {
            "index": index,
            "type": data[0],
            "x": int(data[1]),
            "y": int(data[2]),
            "pos": (int(data[1]), int(data[2])),
            "size": int(data[3]),
            "health": int(data[4]),
            "fruits": int(data[5]),
            "cooldown": int(data[6]),
        }
        trees.append(tree)
        current_tree_positions.add(tree["pos"])

    home_orchard_count = sum(
        1
        for tree in trees
        if tree["pos"] in plant_cells and distance_to_drop(tree["pos"]) <= PLANT_RADIUS
    )

    trolls_count = int(input())
    my_trolls = []
    occupied = set()
    for _ in range(trolls_count):
        data = [int(j) for j in input().split()]
        if data[1] != 0:
            continue
        troll = {
            "id": data[0],
            "pos": (data[2], data[3]),
            "speed": max(1, data[4]),
            "capacity": data[5],
            "harvest": data[6],
            "chop": data[7],
            "carry": dict(zip(RESOURCE_TYPES, data[8:14])),
        }
        my_trolls.append(troll)
        occupied.add(troll["pos"])

    actions = []
    reserved_destinations = set(occupied)
    reserved_fruits = {}
    reserved_chop_power = {}
    reserved_iron = 0
    planned_plants = 0
    planned_seed_pickups = 0

    train_plan = pick_training_plan(len(my_trolls), stock, turn, home_orchard_count)
    wanted_cost = wanted_training_cost(len(my_trolls), stock, turn, home_orchard_count)
    needs = {
        res: max(0, wanted_cost.get(res, 0) - stock.get(res, 0))
        for res in ("PLUM", "LEMON", "APPLE", "IRON")
    }

    # Full trolls and fast trolls first: they create the most immediate value.
    my_trolls.sort(
        key=lambda t: (
            carried_total(t) < t["capacity"],
            -t["speed"],
            -t["capacity"],
            t["id"],
        )
    )

    for troll in my_trolls:
        tid = troll["id"]
        pos = troll["pos"]
        speed = troll["speed"]
        capacity = troll["capacity"]
        cargo = carried_total(troll)
        free = max(0, capacity - cargo)
        orchard_size = home_orchard_count + planned_plants + planned_seed_pickups
        core_ready = len(my_trolls) >= EARLY_TROLL_TARGET or turn > CATCHUP_TRAIN_END
        allow_planting = turn >= EARLY_ORCHARD_START_TURN and (
            len(my_trolls) >= 3 or turn > 80
        )
        seed = (
            carried_seed_type(troll, stock, wanted_cost, turn, orchard_size, core_ready)
            if allow_planting
            else None
        )

        if (
            seed is not None
            and pos in plant_cells
            and distance_to_drop(pos) <= PLANT_RADIUS
            and pos not in current_tree_positions
        ):
            actions.append(f"PLANT {tid} {seed}")
            current_tree_positions.add(pos)
            planned_plants += 1
            continue

        if seed is not None:
            target, plant_dist = best_plant_cell(pos, reserved_destinations, turn)
            if target is not None and plant_dist <= PLANT_MAX_TRAVEL:
                reserved_destinations.add(target)
                current_tree_positions.add(target)
                planned_plants += 1
                actions.append(f"MOVE {tid} {target[0]} {target[1]}")
                continue

        if allow_planting and cargo == 0 and free > 0 and is_next_to_base(pos):
            seed_from_stock = stock_seed_type(
                stock,
                wanted_cost,
                turn,
                orchard_size,
                core_ready,
            )
            plant_target, plant_dist = best_plant_cell(pos, reserved_destinations, turn)
            if (
                seed_from_stock is not None
                and plant_target is not None
                and plant_dist <= PLANT_MAX_TRAVEL
            ):
                actions.append(f"PICK {tid} {seed_from_stock}")
                stock[seed_from_stock] -= 1
                current_tree_positions.add(plant_target)
                planned_plants += 1
                continue

        if (
            allow_planting
            and cargo == 0
            and free > 0
            and not is_next_to_base(pos)
            and planned_seed_pickups == 0
            and orchard_size < orchard_target(turn)
            and has_seed_in_stock(stock, wanted_cost, turn, core_ready)
            and distance_to_drop(pos) <= ORCHARD_RADIUS + 5
        ):
            target = best_drop_cell(pos, reserved_destinations)
            if target == base:
                actions.append(f"MOVE {tid} {base[0]} {base[1]}")
            else:
                reserved_destinations.add(target)
                actions.append(f"MOVE {tid} {target[0]} {target[1]}")
            planned_seed_pickups += 1
            continue

        if cargo > 0 and is_next_to_base(pos):
            actions.append(f"DROP {tid}")
            continue

        if cargo > 0 and (free == 0 or cargo * 4 >= capacity * 3 or turn > 270):
            target = best_drop_cell(pos, reserved_destinations)
            if target == base:
                actions.append(f"MOVE {tid} {base[0]} {base[1]}")
            else:
                reserved_destinations.add(target)
                actions.append(f"MOVE {tid} {target[0]} {target[1]}")
            continue

        best = None
        best_score = -1.0

        # Harvest fruit that exists now. Needed training resources receive a
        # large bonus; bananas remain useful raw points and seed material.
        if free > 0 and troll["harvest"] > 0:
            for tree in trees:
                available = tree["fruits"] - reserved_fruits.get(tree["index"], 0)
                if available <= 0:
                    continue
                target = tree["pos"]
                if target in reserved_destinations and target != pos:
                    continue
                d = dist(pos, target)
                if d >= INF:
                    continue

                amount = min(available, troll["harvest"], free)
                if amount <= 0:
                    continue

                fruit = tree["type"]
                base_value = 24
                if needs.get(fruit, 0) > 0:
                    base_value += 95 + 20 * min(needs[fruit], amount)
                elif wanted_cost and fruit in TRAIN_FRUITS:
                    base_value += 12

                travel_turns = ceil_div(d, speed)
                home_distance = distance_to_drop(target)
                return_turns = ceil_div(home_distance, speed)

                if turn >= ENDGAME_STRICT_TURN and home_distance > ORCHARD_RADIUS:
                    continue
                if turn >= ENDGAME_LOCAL_TURN and home_distance > ORCHARD_RADIUS + 4:
                    continue
                if travel_turns + return_turns + 1 > 300 - turn:
                    continue

                effort = 1 + travel_turns + 0.35 * return_turns
                score = amount * base_value / max(1.0, effort)

                if turn >= MIDGAME_LOCAL_TURN:
                    if target in plant_cells or home_distance <= ORCHARD_RADIUS:
                        score *= 1.25
                    elif home_distance > ORCHARD_RADIUS + 4:
                        score *= 0.55
                if turn >= 160 and home_distance > ORCHARD_RADIUS:
                    score *= 0.45
                if turn >= 200 and home_distance > ORCHARD_RADIUS + 6:
                    score *= 0.35

                # Stepping onto a ripe tree is especially efficient.
                if d == 0:
                    score *= 1.35

                if score > best_score:
                    best_score = score
                    best = {
                        "kind": "HARVEST",
                        "target": target,
                        "tree": tree,
                        "amount": amount,
                    }

        # Mining is only useful when it unlocks more trolls.
        iron_need = max(0, needs["IRON"] - reserved_iron)
        if free > 0 and troll["chop"] > 0 and iron_need > 0:
            target, d = best_mine_spot(pos, reserved_destinations)
            if target is not None and d < INF:
                amount = min(troll["chop"], free, max(1, iron_need))
                travel_turns = ceil_div(d, speed)
                return_turns = ceil_div(distance_to_drop(target), speed)
                score = amount * 130 / max(1.0, 1 + travel_turns + 0.30 * return_turns)
                if d == 0:
                    score *= 1.25
                if score > best_score:
                    best_score = score
                    best = {
                        "kind": "MINE",
                        "target": target,
                        "amount": amount,
                    }

        # Wood scores 4 points, but chopping too many young productive trees
        # early is costly. Turn it on gradually and prefer easy kills.
        if free > 0 and troll["chop"] > 0:
            for tree in trees:
                target = tree["pos"]
                if should_keep_orchard_tree(tree, turn):
                    continue
                if tree["fruits"] > 0 and turn < WOOD_ALL_IN_TURN:
                    continue
                if target in reserved_destinations and target != pos:
                    continue
                d = dist(pos, target)
                if d >= INF:
                    continue

                remaining_health = max(
                    1,
                    tree["health"] - reserved_chop_power.get(tree["index"], 0),
                )
                if reserved_chop_power.get(tree["index"], 0) >= tree["health"]:
                    continue

                chop_turns = ceil_div(remaining_health, troll["chop"])
                wood_amount = min(tree["size"], free)
                home_distance = distance_to_drop(target)
                return_turns = ceil_div(home_distance, speed)

                if turn >= ENDGAME_STRICT_TURN and home_distance > ORCHARD_RADIUS + 2:
                    continue
                if turn >= ENDGAME_LOCAL_TURN and home_distance > ORCHARD_RADIUS + 6:
                    continue
                travel_turns = ceil_div(d, speed)
                if travel_turns + chop_turns + return_turns > 300 - turn:
                    continue

                if turn < WOOD_START_TURN and tree["size"] >= 3 and tree["cooldown"] <= 4:
                    phase = 0.20
                elif turn < 150:
                    phase = 0.55
                elif turn >= WOOD_ALL_IN_TURN:
                    phase = 2.30
                elif turn >= WOOD_HARVEST_TURN and home_distance <= ORCHARD_RADIUS:
                    phase = 1.65
                else:
                    phase = 1.05

                # Damaged or small trees are cheap wood; mature trees with a
                # long cooldown are less painful to remove.
                if tree["health"] <= troll["chop"] or tree["size"] <= 2:
                    phase += 0.30
                if tree["size"] == 4 and tree["cooldown"] > 5:
                    phase += 0.20
                if tree["pos"] in plant_cells:
                    phase += 0.35
                if turn >= WOOD_ALL_IN_TURN and tree["fruits"] > 0:
                    phase += 0.40

                effort = travel_turns + chop_turns + 0.35 * return_turns
                score = wood_amount * 105 * phase / max(1.0, effort)
                if d == 0:
                    score *= 1.20

                if score > best_score:
                    best_score = score
                    best = {
                        "kind": "CHOP",
                        "target": target,
                        "tree": tree,
                    }

        # If nothing is ripe yet, move toward a mature tree that will soon pay.
        if best is None and free > 0 and troll["harvest"] > 0:
            for tree in trees:
                if tree["size"] < 4 or tree["fruits"] > 0:
                    continue
                target = tree["pos"]
                if target in reserved_destinations and target != pos:
                    continue
                d = dist(pos, target)
                if d >= INF:
                    continue
                home_distance = distance_to_drop(target)
                if turn >= ENDGAME_STRICT_TURN and home_distance > ORCHARD_RADIUS:
                    continue
                if turn >= ENDGAME_LOCAL_TURN and home_distance > ORCHARD_RADIUS + 4:
                    continue
                if turn >= MIDGAME_LOCAL_TURN and home_distance > ORCHARD_RADIUS + 6:
                    continue
                travel_turns = ceil_div(d, speed)
                wait_turns = max(0, tree["cooldown"] - travel_turns)
                score = 22 / max(1, travel_turns + wait_turns)
                if score > best_score:
                    best_score = score
                    best = {
                        "kind": "WAIT_FRUIT",
                        "target": target,
                        "tree": tree,
                    }

        if best is None:
            if cargo > 0:
                target = best_drop_cell(pos, reserved_destinations)
                if target == base:
                    actions.append(f"MOVE {tid} {base[0]} {base[1]}")
                else:
                    reserved_destinations.add(target)
                    actions.append(f"MOVE {tid} {target[0]} {target[1]}")
            elif (
                allow_planting
                and free > 0
                and turn > TRAIN_RUSH_END
                and turn < PLANT_UNTIL_TURN
                and orchard_size < orchard_target(turn)
                and has_seed_in_stock(stock, wanted_cost, turn, core_ready)
            ):
                target = best_drop_cell(pos, reserved_destinations)
                if target == base:
                    actions.append(f"MOVE {tid} {base[0]} {base[1]}")
                else:
                    reserved_destinations.add(target)
                    actions.append(f"MOVE {tid} {target[0]} {target[1]}")
            continue

        target = best["target"]
        if best["kind"] == "HARVEST":
            reserved_fruits[best["tree"]["index"]] = (
                reserved_fruits.get(best["tree"]["index"], 0) + best["amount"]
            )
            if target == pos:
                actions.append(f"HARVEST {tid}")
            else:
                reserved_destinations.add(target)
                actions.append(f"MOVE {tid} {target[0]} {target[1]}")
        elif best["kind"] == "MINE":
            reserved_iron += best["amount"]
            if target == pos:
                actions.append(f"MINE {tid}")
            else:
                reserved_destinations.add(target)
                actions.append(f"MOVE {tid} {target[0]} {target[1]}")
        elif best["kind"] == "CHOP":
            reserved_chop_power[best["tree"]["index"]] = (
                reserved_chop_power.get(best["tree"]["index"], 0) + troll["chop"]
            )
            if target == pos:
                actions.append(f"CHOP {tid}")
            else:
                reserved_destinations.add(target)
                actions.append(f"MOVE {tid} {target[0]} {target[1]}")
        else:
            if target != pos:
                reserved_destinations.add(target)
                actions.append(f"MOVE {tid} {target[0]} {target[1]}")

    if train_plan is not None:
        actions.append(f"TRAIN {train_plan[0]} {train_plan[1]} {train_plan[2]} {train_plan[3]}")

    print(";".join(actions) if actions else "WAIT")
    sys.stdout.flush()
    turn += 1
