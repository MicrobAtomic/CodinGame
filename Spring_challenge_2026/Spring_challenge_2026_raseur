import sys
from collections import deque


# Bot raseur: l'objectif est de priver l'adversaire de fruits.
# On recolte/minage uniquement pour produire des coupeurs, puis on coupe
# les arbres, en priorite ceux proches du camp adverse et ceux avec fruits.

RESOURCE_TYPES = ("PLUM", "LEMON", "APPLE", "BANANA", "IRON", "WOOD")
TRAIN_FRUITS = ("PLUM", "LEMON", "APPLE")
DIRS = ((1, 0), (-1, 0), (0, 1), (0, -1))
INF = 10**9

CORE_TROLL_TARGET = 4
TOTAL_TROLL_TARGET = 7
CHOPPER_TARGET = 5
TRAIN_UNTIL_TURN = 210

EARLY_TRAIN_PLANS = (
    (1, 1, 1, 1),
    (1, 1, 1, 0),
)
CHOPPER_TRAIN_PLANS = (
    (1, 2, 1, 2),
    (1, 1, 1, 2),
    (1, 2, 1, 1),
    (1, 1, 1, 1),
)

ENEMY_CAMP_RADIUS = 6
ENEMY_CAMP_HARD_RADIUS = 3
OWN_CAMP_RADIUS = 6
OWN_CAMP_HARD_RADIUS = 2
LOCAL_TREE_RADIUS = 7
ENDGAME_TURN = 240


def ceil_div(a, b):
    return (a + b - 1) // b if b > 0 else INF


def train_cost(plan, troll_count):
    move_speed, capacity, harvest_power, chop_power = plan
    return {
        "PLUM": troll_count + move_speed * move_speed,
        "LEMON": troll_count + capacity * capacity,
        "APPLE": troll_count + harvest_power * harvest_power,
        "IRON": troll_count + chop_power * chop_power,
    }


def can_pay(cost, stock):
    return all(stock[res] >= amount for res, amount in cost.items())


def training_options(troll_count, chopper_count, turn):
    if turn > TRAIN_UNTIL_TURN:
        return ()
    if troll_count < CORE_TROLL_TARGET:
        return EARLY_TRAIN_PLANS
    if troll_count < TOTAL_TROLL_TARGET and chopper_count < CHOPPER_TARGET:
        return CHOPPER_TRAIN_PLANS + EARLY_TRAIN_PLANS
    if troll_count < CORE_TROLL_TARGET + 1 and turn < 120:
        return EARLY_TRAIN_PLANS
    return ()


def pick_training_plan(troll_count, chopper_count, stock, turn):
    for plan in training_options(troll_count, chopper_count, turn):
        if can_pay(train_cost(plan, troll_count), stock):
            return plan
    return None


def wanted_training_cost(troll_count, chopper_count, stock, turn):
    options = training_options(troll_count, chopper_count, turn)
    if not options:
        return {}

    for plan in options:
        cost = train_cost(plan, troll_count)
        if can_pay(cost, stock):
            return cost
    return train_cost(options[0], troll_count)


width, height = [int(i) for i in input().split()]
base = (0, 0)
enemy_base = None
iron_cells = []
water_cells = set()
walkable = set()

for y in range(height):
    line = input()
    for x, char in enumerate(line):
        pos = (x, y)
        if char == "0":
            base = pos
            walkable.add(pos)
        elif char == "1":
            enemy_base = pos
        elif char == ".":
            walkable.add(pos)
        elif char == "+":
            iron_cells.append(pos)
        elif char == "~":
            water_cells.add(pos)


def bfs(start):
    distances = {start: 0}
    queue = deque([start])
    while queue:
        x, y = queue.popleft()
        for dx, dy in DIRS:
            nxt = (x + dx, y + dy)
            if nxt in walkable and nxt != base and nxt not in distances:
                distances[nxt] = distances[(x, y)] + 1
                queue.append(nxt)
    return distances


distances_from = {cell: bfs(cell) for cell in walkable}

drop_cells = []
for dx, dy in DIRS:
    cell = (base[0] + dx, base[1] + dy)
    if cell in walkable:
        drop_cells.append(cell)

enemy_camp_cells = []
if enemy_base is not None:
    for dx, dy in DIRS:
        cell = (enemy_base[0] + dx, enemy_base[1] + dy)
        if cell in walkable:
            enemy_camp_cells.append(cell)

mine_spots = []
for mx, my in iron_cells:
    for dx, dy in DIRS:
        spot = (mx + dx, my + dy)
        if spot in walkable:
            mine_spots.append(spot)
mine_spots = list(dict.fromkeys(mine_spots))

water_adjacent = set()
for x, y in walkable:
    for dx, dy in DIRS:
        if (x + dx, y + dy) in water_cells:
            water_adjacent.add((x, y))
            break


def dist(a, b):
    if a == b:
        return 0
    return distances_from.get(a, {}).get(b, INF)


def is_next_to_base(pos):
    return abs(pos[0] - base[0]) + abs(pos[1] - base[1]) == 1


def distance_to_cells(pos, cells):
    return min((dist(pos, cell) for cell in cells), default=INF)


def distance_to_drop(pos):
    if is_next_to_base(pos):
        return 0
    return distance_to_cells(pos, drop_cells)


def distance_to_enemy_camp(pos):
    return distance_to_cells(pos, enemy_camp_cells)


def best_drop_cell(pos, reserved):
    best_cell = None
    best_dist = INF
    for cell in drop_cells:
        if cell in reserved and cell != pos:
            continue
        d = dist(pos, cell)
        if d < best_dist:
            best_dist = d
            best_cell = cell
    return best_cell if best_cell is not None else base


def best_mine_spot(pos, reserved):
    best_cell = None
    best_dist = INF
    for cell in mine_spots:
        if cell in reserved and cell != pos:
            continue
        d = dist(pos, cell)
        if d < best_dist:
            best_dist = d
            best_cell = cell
    return best_cell, best_dist


def next_step_towards(pos, target, speed, reserved):
    if target == base:
        return base
    if pos == target:
        return pos

    seen = {pos: 0}
    queue = deque([pos])
    while queue:
        cell = queue.popleft()
        if seen[cell] >= speed:
            continue
        x, y = cell
        for dx, dy in DIRS:
            nxt = (x + dx, y + dy)
            if nxt in seen or nxt not in walkable or nxt == base:
                continue
            if nxt in reserved and nxt != target:
                continue
            seen[nxt] = seen[cell] + 1
            queue.append(nxt)

    best_cell = pos
    best_score = (dist(pos, target), 0)
    for cell, steps in seen.items():
        if cell != pos and cell in reserved and cell != target:
            continue
        d = dist(cell, target)
        if d >= INF:
            continue
        score = (d, -steps)
        if score < best_score:
            best_score = score
            best_cell = cell
    return best_cell


def add_move(actions, reserved, tid, pos, target, speed):
    destination = next_step_towards(pos, target, speed, reserved)
    if destination == pos:
        return False
    if destination != base:
        reserved.discard(pos)
        reserved.add(destination)
    actions.append(f"MOVE {tid} {destination[0]} {destination[1]}")
    return True


def carried_total(troll):
    return sum(troll["carry"].values())


def carried_wood(troll):
    return troll["carry"]["WOOD"]


def tree_enemy_pressure(tree):
    d = distance_to_enemy_camp(tree["pos"])
    if d <= ENEMY_CAMP_HARD_RADIUS:
        return 1100
    if d <= ENEMY_CAMP_RADIUS:
        return 650 - 70 * d
    return 0


def tree_own_pressure(tree):
    d = distance_to_drop(tree["pos"])
    if d <= OWN_CAMP_HARD_RADIUS:
        return 1500
    if d <= OWN_CAMP_RADIUS:
        return 950 - 80 * d
    return 0


def tree_chop_score(tree, troll, travel, turn):
    chop_turns = ceil_div(max(1, tree["health"]), troll["chop"])
    home_distance = distance_to_drop(tree["pos"])
    enemy_distance = distance_to_enemy_camp(tree["pos"])

    score = 130 * tree["size"]
    score += tree_own_pressure(tree)
    score += tree_enemy_pressure(tree)
    if tree["fruits"] > 0:
        score += 430 + 80 * tree["fruits"]
    if tree["pos"] in water_adjacent:
        score += 180
    if tree["size"] >= 3:
        score += 140
    if enemy_distance <= ENEMY_CAMP_RADIUS and tree["size"] <= 2:
        score += 120
    if turn >= ENDGAME_TURN:
        score += 180 * tree["size"]

    score -= 40 * ceil_div(travel, troll["speed"])
    score -= 18 * chop_turns
    score -= 4 * ceil_div(home_distance, troll["speed"])
    return score


def pick_chop_target(troll, trees, reserved_destinations, reserved_chop_power, turn):
    best = None
    best_score = -INF
    pos = troll["pos"]
    for tree in trees:
        if reserved_chop_power.get(tree["index"], 0) >= tree["health"]:
            continue
        target = tree["pos"]
        if target in reserved_destinations and target != pos:
            continue
        d = dist(pos, target)
        if d >= INF:
            continue
        score = tree_chop_score(tree, troll, d, turn)
        if score > best_score:
            best_score = score
            best = tree
    return best


def pick_harvest_target(troll, trees, reserved_destinations, reserved_fruits, needs):
    best = None
    best_score = -INF
    pos = troll["pos"]
    for tree in trees:
        available = tree["fruits"] - reserved_fruits.get(tree["index"], 0)
        if available <= 0:
            continue
        fruit = tree["type"]
        need = needs.get(fruit, 0)
        if need <= 0 and tree["fruits"] < 3:
            continue
        target = tree["pos"]
        if target in reserved_destinations and target != pos:
            continue
        d = dist(pos, target)
        if d >= INF:
            continue
        amount = min(available, troll["harvest"], troll["free"])
        if amount <= 0:
            continue

        score = 70 * amount
        if need > 0:
            score += 520 + 130 * min(need, amount)
        if distance_to_enemy_camp(target) <= ENEMY_CAMP_RADIUS:
            score += 150
        score -= 35 * ceil_div(d, troll["speed"])
        score -= 4 * ceil_div(distance_to_drop(target), troll["speed"])
        if d == 0:
            score += 80
        if score > best_score:
            best_score = score
            best = (tree, amount)
    return best


turn = 0

while True:
    inventories = []
    for _ in range(2):
        values = [int(j) for j in input().split()]
        inventories.append(dict(zip(RESOURCE_TYPES, values)))

    stock = inventories[0]

    tree_count = int(input())
    trees = []
    for index in range(tree_count):
        data = input().split()
        tree = {
            "index": index,
            "type": data[0],
            "pos": (int(data[1]), int(data[2])),
            "size": int(data[3]),
            "health": int(data[4]),
            "fruits": int(data[5]),
            "cooldown": int(data[6]),
        }
        trees.append(tree)

    trolls_count = int(input())
    my_trolls = []
    occupied = set()
    for _ in range(trolls_count):
        data = [int(j) for j in input().split()]
        if data[1] != 0:
            continue
        troll = {
            "id": data[0],
            "pos": (data[2], data[3]),
            "speed": max(1, data[4]),
            "capacity": data[5],
            "harvest": data[6],
            "chop": data[7],
            "carry": dict(zip(RESOURCE_TYPES, data[8:14])),
        }
        troll["cargo"] = carried_total(troll)
        troll["free"] = max(0, troll["capacity"] - troll["cargo"])
        my_trolls.append(troll)
        occupied.add(troll["pos"])

    chopper_count = sum(1 for troll in my_trolls if troll["chop"] > 0)
    train_plan = pick_training_plan(len(my_trolls), chopper_count, stock, turn)
    wanted_cost = wanted_training_cost(len(my_trolls), chopper_count, stock, turn)
    needs = {
        res: max(0, wanted_cost.get(res, 0) - stock.get(res, 0))
        for res in ("PLUM", "LEMON", "APPLE", "IRON")
    }

    actions = []
    reserved_destinations = set(occupied)
    reserved_fruits = {}
    reserved_chop_power = {}
    reserved_iron = 0

    my_trolls.sort(
        key=lambda t: (
            t["cargo"] == 0,
            -t["chop"],
            -t["speed"],
            -t["capacity"],
            t["id"],
        )
    )

    for troll in my_trolls:
        tid = troll["id"]
        pos = troll["pos"]
        speed = troll["speed"]
        cargo = troll["cargo"]
        free = troll["free"]

        if cargo > 0 and is_next_to_base(pos):
            actions.append(f"DROP {tid}")
            continue

        if cargo > 0 and (free == 0 or carried_wood(troll) > 0 or turn > 270):
            target = best_drop_cell(pos, reserved_destinations)
            add_move(actions, reserved_destinations, tid, pos, target, speed)
            continue

        best = None
        best_score = -INF

        iron_need = max(0, needs["IRON"] - reserved_iron)
        if free > 0 and troll["chop"] > 0 and iron_need > 0:
            target, d = best_mine_spot(pos, reserved_destinations)
            if target is not None and d < INF:
                amount = min(troll["chop"], free, iron_need)
                score = 780 + 160 * amount - 35 * ceil_div(d, speed)
                if score > best_score:
                    best_score = score
                    best = ("MINE", target, amount, None)

        if free > 0 and troll["harvest"] > 0:
            harvest = pick_harvest_target(
                troll,
                trees,
                reserved_destinations,
                reserved_fruits,
                needs,
            )
            if harvest is not None:
                tree, amount = harvest
                d = dist(pos, tree["pos"])
                score = 620 + 160 * amount - 40 * ceil_div(d, speed)
                if needs.get(tree["type"], 0) > 0:
                    score += 500
                if score > best_score:
                    best_score = score
                    best = ("HARVEST", tree["pos"], amount, tree)

        if free > 0 and troll["chop"] > 0:
            tree = pick_chop_target(
                troll,
                trees,
                reserved_destinations,
                reserved_chop_power,
                turn,
            )
            if tree is not None:
                d = dist(pos, tree["pos"])
                score = tree_chop_score(tree, troll, d, turn)
                if len(my_trolls) < CORE_TROLL_TARGET and any(needs.values()):
                    score *= 0.55
                if score > best_score:
                    best_score = score
                    best = ("CHOP", tree["pos"], troll["chop"], tree)

        if best is None:
            if cargo > 0:
                target = best_drop_cell(pos, reserved_destinations)
                add_move(actions, reserved_destinations, tid, pos, target, speed)
            continue

        kind, target, amount, tree = best
        if kind == "MINE":
            if target == pos:
                reserved_iron += amount
                actions.append(f"MINE {tid}")
            else:
                if add_move(actions, reserved_destinations, tid, pos, target, speed):
                    reserved_iron += amount
        elif kind == "HARVEST":
            if target == pos:
                reserved_fruits[tree["index"]] = (
                    reserved_fruits.get(tree["index"], 0) + amount
                )
                actions.append(f"HARVEST {tid}")
            else:
                if add_move(actions, reserved_destinations, tid, pos, target, speed):
                    reserved_fruits[tree["index"]] = (
                        reserved_fruits.get(tree["index"], 0) + amount
                    )
        elif kind == "CHOP":
            if target == pos:
                reserved_chop_power[tree["index"]] = (
                    reserved_chop_power.get(tree["index"], 0) + amount
                )
                actions.append(f"CHOP {tid}")
            else:
                if add_move(actions, reserved_destinations, tid, pos, target, speed):
                    reserved_chop_power[tree["index"]] = (
                        reserved_chop_power.get(tree["index"], 0) + amount
                    )

    if train_plan is not None:
        actions.append(f"TRAIN {train_plan[0]} {train_plan[1]} {train_plan[2]} {train_plan[3]}")

    print(";".join(actions) if actions else "WAIT")
    sys.stdout.flush()
    turn += 1
